PORT=3000
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# PostgreSQL connection string (from Render dashboard or Neon.tech)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your Stripe Price IDs (create products in Stripe dashboard first)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# Your app's public URL (needed for Stripe redirects)
APP_URL=https://your-app.onrender.com

# Admin account (set this before first run)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-strong-password
